# PetMatching Docker Environment Variables
# Copy this file to .env and update the values

# Database Configuration
MYSQL_ROOT_PASSWORD=secure_root_password_change_me
MYSQL_DATABASE=petmatching
MYSQL_USERNAME=petmatching_user
MYSQL_PASSWORD=secure_user_password_change_me

# JWT Configuration
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_minimum_256_bits_long_change_this
JWT_ACCESS_TOKEN_EXPIRATION=PT15M
JWT_REFRESH_TOKEN_EXPIRATION=PT168H

# OAuth Configuration (Kakao)
KAKAO_CLIENT_ID=27f36d6e010908844fbe8b200a8e25d8
KAKAO_CLIENT_SECRET=your_kakao_client_secret_here

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8080